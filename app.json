{
  "expo": {
    "name": "RegistroOcorrencias",
    "slug": "RegistroOcorrencias",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.wuendervoidrel.registroocorrencias",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Usamos a câmera para registrar fotos da ocorrência de campo."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Usamos sua localização para marcar onde a ocorrência aconteceu."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "68f43958-3382-45be-88db-78fcd641d17a"
      }
    },
    "owner": "wuender_void"
  }
}
